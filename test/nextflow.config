/*
 * test/nextflow.config — profile for the stub smoke test.
 *
 * Uses the local executor, pre-wires --input to the tiny stub samplesheet,
 * and disables resource-heavy settings. Intended to be invoked as:
 *
 *   nextflow run main.nf -profile test -stub \
 *       --casetrack_project_dir /tmp/casetrack_smoke/proj \
 *       --run_tag 20260418_hg38_v1
 */

params {
    input = "${projectDir}/test/samplesheet.csv"
    fasta = "${projectDir}/test/data/stub.fa"
    fai   = "${projectDir}/test/data/stub.fa.fai"
}

process {
    executor = 'local'
    cpus     = 1
    memory   = '500 MB'
    time     = '10m'

    // Override every resource label — the smoke test runs on small hosts,
    // and process_high's 8-CPU default is larger than CI boxes or laptops.
    withLabel: process_single { cpus = 1; memory = '500 MB' }
    withLabel: process_low    { cpus = 1; memory = '500 MB' }
    withLabel: process_medium { cpus = 1; memory = '500 MB' }
    withLabel: process_high   { cpus = 1; memory = '500 MB' }
}
