/*
 * custom.config — for the GIAB chr21 pilot.
 *
 * Gotchas handled here (from proposal 0004 §Pilot):
 *   1. The nf-core module's container ternary falls through to the docker.io
 *      biocontainer URL when workflow.containerEngine != 'singularity' (true
 *      under Apptainer). Pinning the Galaxy depot URL sidesteps that.
 *   2. SUMMARIZE_MODKIT OOMs at 2 GB on a ~55M-row chr21 bedMethyl even
 *      though the script is streaming — Python interpreter overhead + gzip
 *      buffers need headroom. 4 GB is comfortable.
 */

apptainer.cacheDir = '/data1/greenbab/users/ahunos/apptainer_cache'

process {
    withName: 'MODKIT_PILEUP_TRACKED:MODKIT_PILEUP' {
        container = 'https://depot.galaxyproject.org/singularity/ont-modkit:0.6.1--hcdda2d0_0'
        cpus      = 4
        memory    = '16 GB'
        time      = '4h'
    }

    withName: 'MODKIT_PILEUP_TRACKED:SUMMARIZE_MODKIT' {
        cpus   = 1
        memory = '4 GB'
        time   = '30m'
    }
}
