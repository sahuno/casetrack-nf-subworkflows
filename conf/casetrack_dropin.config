/*
 * casetrack_dropin.config — add casetrack tracking to ANY nf-core pipeline
 *                          without modifying it.
 *
 * Usage (from a pipeline invocation, e.g. nf-core/methylong):
 *
 *   nextflow run nf-core/methylong -r 2.0.0 \
 *       -c /path/to/casetrack_dropin.config \
 *       --casetrack_project_dir /abs/path/to/project \
 *       --run_tag 20260419_hg38_methylong_v1 \
 *       --casetrack_level specimen \
 *       ... other methylong params ...
 *
 * What it does:
 *   - Enables extended Nextflow trace fields (process, tag, queue, attempt)
 *     that the casetrack trace parser needs.
 *   - Enables report/trace/timeline/dag reports next to the casetrack project.
 *   - On pipeline completion, invokes bin/trace_to_casetrack.py (L2) and
 *     bin/versions_to_casetrack.py (L3) from the casetrack-nf-subworkflows
 *     repo against the casetrack project.
 *   - Data columns (L1) are NOT added here — that requires per-tool
 *     wrapper subworkflows, which only apply to pipelines YOU author.
 *     With a drop-in like this, you get trace + versions tracking for free.
 *
 * For L1 data columns when running a stock nf-core pipeline:
 *   author a post-processing step in your own pipeline that calls our
 *   CASETRACK_REGISTER module against the nf-core pipeline's published
 *   output. See docs/TUTORIAL.md §Adding a new tracked tool.
 *
 * Required params (fail fast if missing):
 *   casetrack_project_dir  absolute path to the casetrack project
 *   run_tag                {date}_{genome}_{description}
 *
 * Optional params:
 *   casetrack_level             'patient' | 'specimen' | 'assay' (default 'assay')
 *   casetrack_helper_dir        absolute path to casetrack-nf-subworkflows/bin
 *                               (falls back to $CASETRACK_HELPER_DIR env var)
 *   casetrack_samplesheet_key_col  column name in the pipeline's samplesheet that
 *                               holds the casetrack entity id at the target level
 *                               (default 'sample' — matches most nf-core pipelines)
 *   casetrack_bin               casetrack CLI (default 'casetrack')
 *   casetrack_import_trace      true|false (default true)
 *   casetrack_import_versions   true|false (default true)
 */

params {
    // ── required: must be overridden on the CLI or in a site/overlay config
    casetrack_project_dir        = null
    run_tag                      = null

    // ── optional (with defaults)
    casetrack_level              = 'assay'
    casetrack_samplesheet_key_col = 'sample'
    casetrack_bin                = 'casetrack'
    casetrack_import_trace       = true
    casetrack_import_versions    = true
    casetrack_helper_dir         = System.getenv('CASETRACK_HELPER_DIR') ?: null
}

// ── extended trace fields (process/tag/queue/attempt are not in the default set) ──
def _ct_report_dir = params.casetrack_project_dir && params.run_tag
    ? "${params.casetrack_project_dir}/results/_nextflow/${params.run_tag}"
    : "${launchDir}/casetrack_nextflow_reports"

trace {
    enabled   = true
    overwrite = true
    file      = "${_ct_report_dir}/execution_trace.txt"
    fields    = 'task_id,hash,native_id,process,tag,name,status,exit,submit,start,complete,duration,realtime,%cpu,peak_rss,peak_vmem,rchar,wchar,queue,attempt'
}
report   { enabled = true; overwrite = true; file = "${_ct_report_dir}/execution_report.html" }
timeline { enabled = true; overwrite = true; file = "${_ct_report_dir}/execution_timeline.html" }
dag      { enabled = true; overwrite = true; file = "${_ct_report_dir}/pipeline_dag.html" }


// ── onComplete hook — L2 + L3 imports ──
workflow.onComplete = {
    if (!params.casetrack_project_dir) {
        System.err.println "[casetrack] casetrack_project_dir not set — skipping import"
        return
    }
    if (!params.run_tag) {
        System.err.println "[casetrack] run_tag not set — skipping import"
        return
    }

    def helper_dir = params.casetrack_helper_dir
    if (!helper_dir) {
        System.err.println "[casetrack] casetrack_helper_dir not set and CASETRACK_HELPER_DIR env unset — skipping import"
        System.err.println "[casetrack] set either with --casetrack_helper_dir /path/to/casetrack-nf-subworkflows/bin"
        return
    }

    def run_tag = params.run_tag.toString()
    def proj    = params.casetrack_project_dir.toString()
    def level   = params.casetrack_level.toString()
    def cbin    = params.casetrack_bin.toString()

    // ── L2 — trace import ──
    if (params.casetrack_import_trace) {
        def trace_path = "${_ct_report_dir}/execution_trace.txt"
        def trace_file = new File(trace_path)
        if (trace_file.exists()) {
            def cmd = [
                "${helper_dir}/trace_to_casetrack.py",
                '--project-dir',  proj,
                '--trace',        trace_path,
                '--run-tag',      run_tag,
                '--level',        level,
                '--casetrack-bin', cbin,
            ]
            System.err.println "[casetrack] L2 trace import: ${cmd.join(' ')}"
            def p = cmd.execute()
            p.consumeProcessOutput(System.out, System.err)
            p.waitFor()
            if (p.exitValue() != 0) {
                System.err.println "[casetrack] L2 trace import rc=${p.exitValue()}"
            }
        } else {
            System.err.println "[casetrack] trace ${trace_path} not found — skipping L2"
        }
    }

    // ── L3 — versions import ──
    if (params.casetrack_import_versions) {
        def versions_path = "${_ct_report_dir}/versions.yml"
        def versions_file = new File(versions_path)
        if (!versions_file.exists()) {
            // nf-core pipelines publish versions at ${outdir}/pipeline_info/nf_core_*_software_mqc_versions.yml
            // Try to locate one there as a fallback.
            def info_dir = params.outdir ? new File("${params.outdir}/pipeline_info") : null
            if (info_dir?.isDirectory()) {
                def candidates = info_dir.listFiles().findAll { it.name.endsWith('_versions.yml') }
                if (candidates) {
                    versions_file = candidates.sort { it.lastModified() }.last()
                    versions_path = versions_file.toString()
                    System.err.println "[casetrack] using nf-core versions file: ${versions_path}"
                }
            }
        }

        if (versions_file.exists()) {
            // Collect the target key column (sample/specimen/patient) from the
            // pipeline's samplesheet, since versions are run-level and need
            // broadcasting to the assays the run covered.
            def ids = []
            if (params.input) {
                try {
                    def rows = new File(params.input.toString()).readLines()
                    def hdr  = rows[0].split(',')
                    def keyi = hdr.findIndexOf { it.trim() == params.casetrack_samplesheet_key_col }
                    if (keyi >= 0) {
                        ids = rows.drop(1).collect {
                            def c = it.split(',')
                            c.size() > keyi ? c[keyi] : null
                        }.findAll { it }.unique()
                    }
                } catch (Exception ex) {
                    System.err.println "[casetrack] could not parse ${params.input}: ${ex.message}"
                }
            }

            if (ids) {
                def cmd = [
                    "${helper_dir}/versions_to_casetrack.py",
                    '--project-dir',  proj,
                    '--versions',     versions_path,
                    '--run-tag',      run_tag,
                    '--assay-ids',    ids.join(','),
                    '--level',        level,
                    '--casetrack-bin', cbin,
                ]
                System.err.println "[casetrack] L3 versions import: ${cmd.join(' ')}"
                def p = cmd.execute()
                p.consumeProcessOutput(System.out, System.err)
                p.waitFor()
                if (p.exitValue() != 0) {
                    System.err.println "[casetrack] L3 versions import rc=${p.exitValue()}"
                }
            } else {
                System.err.println "[casetrack] could not derive ids from ${params.input} col=${params.casetrack_samplesheet_key_col} — skipping L3"
            }
        } else {
            System.err.println "[casetrack] versions file not found — skipping L3"
        }
    }
}
