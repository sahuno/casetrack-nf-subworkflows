/*
 * nextflow.config — top-level defaults for casetrack-nf-subworkflows.
 */

manifest {
    name            = 'casetrack-nf-subworkflows'
    author          = 'Samuel Ahuno <ekwame001@gmail.com>'
    description     = 'Reusable DSL2 subworkflows that wrap nf-core modules with casetrack bookkeeping.'
    mainScript      = 'main.nf'
    nextflowVersion = '>=24.04.0'
    version         = '0.1.0'
}

params {
    // ── required ──
    input                    = null        // samplesheet CSV
    casetrack_project_dir    = null        // absolute path to casetrack project
    run_tag                  = null        // {date}_{genome}_{description}

    // ── tool selection ──
    tool                     = 'modkit_pileup'  // modkit_pileup | modkit_merged | samtools_sort | dorado_basecaller

    // ── reference data ──
    fasta                    = null
    fai                      = null
    bed                      = null        // optional include-bed
    dorado_model             = null        // required when tool=dorado_basecaller

    // ── casetrack CLI ──
    casetrack_bin             = 'casetrack'
    casetrack_import_trace    = true       // L2: import Nextflow trace on completion
    casetrack_import_versions = true       // L3: import topic:versions as {prefix}_*_version cols

    // ── nf-core boilerplate ──
    outdir                   = null        // set per run; derived from casetrack_project_dir by default
    publish_dir_mode         = 'copy'
}

// Default outdir = <casetrack_project_dir>/results when not explicitly set.
if (!params.outdir && params.casetrack_project_dir) {
    params.outdir = "${params.casetrack_project_dir}/results"
}

process {
    cpus   = 1
    memory = '4 GB'
    time   = '2h'

    withLabel: process_single { cpus = 1; memory = '2 GB'; time = '1h' }
    withLabel: process_low     { cpus = 2; memory = '4 GB'; time = '2h' }
    withLabel: process_medium  { cpus = 4; memory = '16 GB'; time = '4h' }
    withLabel: process_high    { cpus = 8; memory = '32 GB'; time = '8h' }

    // casetrack runs locally, never on SLURM — it writes to SQLite on shared
    // storage and contention from many parallel jobs wastes cluster time.
    withName: 'CASETRACK_REGISTER' {
        executor = 'local'
        cpus     = 1
        memory   = '500 MB'
        time     = '15m'
    }
}

profiles {

    standard {
        process.executor = 'local'
    }

    test {
        includeConfig 'test/nextflow.config'
    }

    slurm {
        process {
            executor       = 'slurm'
            queue          = 'componc_cpu'
            clusterOptions = '--account=greenbab'
        }
        executor.queueSize = 50
    }

    apptainer {
        apptainer.enabled    = true
        apptainer.autoMounts = true
        apptainer.runOptions = '--bind /data1/greenbab'
    }

    gpu {
        // GPU jobs: add to slurm profile to request GPU nodes.
        // Usage: -profile slurm,apptainer,gpu
        process {
            withLabel: 'process_high_gpu' {
                clusterOptions = '--gres=gpu:1'
                // Use mem=0 (all node memory) to avoid SLURM_MEM_PER_NODE
                // conflict with srun inside sbatch (CLAUDE.md §6 GPU note).
                memory         = '0'
                cpus           = 8
                time           = '24h'
            }
        }
    }

    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true
        singularity.runOptions = '--bind /data1/greenbab'
    }
}

// Nextflow execution reports live alongside the casetrack project so the
// run is self-contained on disk.
def report_dir = params.casetrack_project_dir
    ? "${params.casetrack_project_dir}/results/_nextflow/${params.run_tag ?: 'unset'}"
    : 'results/_nextflow'

report   { enabled = true; overwrite = true; file = "${report_dir}/execution_report.html" }
trace    {
    enabled   = true
    overwrite = true
    file      = "${report_dir}/execution_trace.txt"
    // Fields consumed by bin/trace_to_casetrack.py (L2). 'process' and 'tag'
    // are not in the Nextflow default set — they're how we map a trace row
    // to (tool, assay_id).
    fields    = 'task_id,hash,native_id,process,tag,name,status,exit,submit,start,complete,duration,realtime,%cpu,peak_rss,peak_vmem,rchar,wchar,queue,attempt'
}
timeline { enabled = true; overwrite = true; file = "${report_dir}/execution_timeline.html" }
dag      { enabled = true; overwrite = true; file = "${report_dir}/pipeline_dag.html" }
